                <g transform="translate(0 -166)">
                  <g>
                    <animateTransform attributeName="transform" type="rotate" from="0" to="-360" dur="72s" repeatCount="indefinite"></animateTransform>
                    <rect x="-68" y="-17" width="136" height="34" rx="17" stroke="currentColor" stroke-width="1.5" fill="none"></rect>
                    <image href="/icons/figma.svg" x="-36" y="-7" width="14" height="14"></image>
                    <text x="10" y="0" text-anchor="middle" dominant-baseline="middle" fill="currentColor" font-size="11" font-weight="300">Figma</text>
