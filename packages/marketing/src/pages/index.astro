---
import { Code } from 'astro:components';
import '../styles/widget.css';
const title = 'tsp — Token Sync Protocol';
const description =
  'Sync design tokens live in both directions between Figma, code, and every connected tool. Keep color, type, and spacing aligned in real time. Free, from Figma.';
---

<!doctype html>
<html lang="en">
  <head>
    <meta charset="UTF-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1.0" />
    <meta name="description" content={description} />
    <meta name="color-scheme" content="light dark" />
    <title>{title}</title>
    <link rel="preconnect" href="https://rsms.me/" crossorigin />
    <link rel="stylesheet" href="https://rsms.me/inter/inter.css" />
    <link rel="canonical" href="https://tsp.figma.com/" />
    <meta property="og:title" content={title} />
    <meta property="og:description" content={description} />
    <meta property="og:url" content="https://tsp.figma.com/" />
  </head>
  <body>
    <header class="site-header">
      <div class="site-header__inner">
        <a href="/" class="wm" aria-label="tsp — Token Sync Protocol">
          <span>tsp</span><span class="wm__proto">://</span>
        </a>
        <nav class="site-nav">
          <a href="#demo" class="nav--desktop">Demo</a>
          <a href="#plugins" class="nav--desktop">Plugins</a>
          <a href="#websites" class="nav--desktop">Websites</a>
          <a href="#developers" class="nav--desktop">Developers</a>
        </nav>
        <div class="site-header__cta">
          <a href="https://github.com/meodai/token-beam" class="site-header__link nav--desktop"
            >GitHub</a
          >
          <a href="#plugins" class="btn btn--primary">Get started</a>
        </div>
      </div>
    </header>

    <main>
      <section class="hero">
        <canvas id="hero-canvas" class="hero__canvas"></canvas>
        <div class="hero__inner">
          <div class="eyebrow">
            <span class="eyebrow__dot" aria-hidden="true"></span>
            by Figma
          </div>
          <h1>
            Keep design tokens in sync between tools and code, in
            <span class="grad-word">real-time</span>.
          </h1>
          <p class="hero-text">
            Sync color, type, and spacing both ways between Figma, your codebase, and every
            connected tool. Make a change anywhere and watch it propagate live. Free, from the
            team at Figma.
          </p>
          <div class="hero-buttons">
            <a href="#plugins" class="btn btn--primary">Get started →</a>
            <a href="#demo" class="btn">See it working</a>
          </div>
        </div>
      </section>

      <section class="diagram sec" id="how-it-works">
        <div class="container">
          <div class="section-header">
            <span class="sec-label">§02 · How it works</span>
            <h2 class="sec-title">One protocol.<br />Every design tool.</h2>
            <p class="sec-lead">
              tsp is a lightweight protocol for two-way token sync between Figma, your IDE,
              Storybook, Framer, and anything else that speaks tokens. Connect once, then let
              changes flow instantly over <code>tsp://</code>.
            </p>
          </div>
          <svg
            class="diagram__svg"
            viewBox="0 0 800 360"
            fill="none"
            xmlns="http://www.w3.org/2000/svg"
            aria-label="tsp architecture diagram: connected apps orbit around the tsp protocol and sync bidirectionally through Figma TSB"
          >
            <defs>
              <marker
                id="diagram-arrow-desktop"
                viewBox="0 0 10 10"
                refX="9"
                refY="5"
                markerWidth="6"
                markerHeight="6"
                orient="auto-start-reverse"
              >
                <path d="M 0 0 L 10 5 L 0 10 z" fill="currentColor" opacity="0.3"></path>
              </marker>
            </defs>
            <circle cx="400" cy="180" r="178" stroke="currentColor" stroke-width="1" stroke-dasharray="4 8" opacity="0.12"></circle>
            <circle cx="400" cy="180" r="68" stroke="currentColor" stroke-width="2" fill="none"></circle>

            <text x="400" y="160" text-anchor="middle" fill="currentColor" font-size="12" font-weight="600" letter-spacing="0.08em" opacity="0.55">tsp://</text>
            <text x="400" y="188" text-anchor="middle" fill="currentColor" font-size="18" font-weight="600">Figma TSB</text>

