      </section>

      <section class="demo sec" id="demo">
        <div class="container">
          <div class="section-header">
            <span class="sec-label">§03 · Live demo</span>
            <h2 class="sec-title">See tokens move,<br />in real time.</h2>
            <p class="sec-lead">
              Open this page beside a plugin. Change tokens on either side and watch the other one
              update live.
            </p>
          </div>
          <div class="demo__step-row">
            <span class="demo__step-number">1</span>
            <p class="demo__step-text">
              <a href="#plugins">Install a plugin</a> for the tool you want to pair
            </p>
          </div>

          <div class="demo__step-row">
            <span class="demo__step-number">2</span>
            <p class="demo__step-text">Copy the session token below</p>
          </div>

          <div class="demo__widget-wrap demo-frame">
            <span class="demo-frame__label">Live demo &middot; session</span>
            <div class="dts-widget" data-dts="widget">
              <div class="dts-widget__row">
                <span class="dts-widget__label">Session</span>
                <div class="dts-widget__token-wrap">
                  <button class="dts-widget__token" data-dts="token" disabled>Connecting...</button>
                  <span class="dts-widget__status" data-dts="status"></span>
                </div>
                <button class="dts-widget__unlink" data-dts="unlink" style="display:none">
                  <span class="dts-widget__dot"></span>
                  <span class="dts-widget__unlink-label">Unlink</span>
                </button>
                <div class="dts-widget__help" data-dts="help-wrap">
                  <button class="dts-widget__help-btn" data-dts="help-btn" aria-expanded="false"
                    >?</button
                  >
                  <div class="dts-widget__tooltip">
                    <p>
                      Copy the session token and paste it into a tsp-enabled plugin to start a
                      live two-way sync session.
                    </p>
                    <p>Available plugins:</p>
                    <ul class="dts-widget__plugins" data-dts="plugin-list">
                      <li>Loading&hellip;</li>
                    </ul>
                  </div>
                </div>
              </div>
              <div class="dts-widget__error" data-dts="error" style="display:none"></div>
              <div class="dts-widget__offline">Offline &mdash; click to reconnect</div>
            </div>
          </div>

          <div class="demo__step-row">
            <span class="demo__step-number">3</span>
            <p class="demo__step-text">Paste the token into your plugin and pair the session</p>
          </div>

          <div class="demo__step-row">
            <span class="demo__step-number">4</span>
            <p class="demo__step-text">
              Change tokens here or in the connected tool and watch both sides stay in sync
            </p>
          </div>

          <div class="demo__widget-wrap">
            <div id="swatches" class="demo__swatches"></div>
            <button class="btn btn--primary btn--block" id="regen-btn">Regenerate Colors</button>
          </div>

          <div class="demo__videos">
            <div class="demo__video-wrap">
              <video class="demo__video" autoplay loop muted playsinline>
                <source src="/video/poline-to-figma.mp4" type="video/mp4" />
              </video>
              <span class="demo__video-label">poline → Figma</span>
            </div>
            <div class="demo__video-wrap">
              <video class="demo__video" autoplay loop muted playsinline>
                <source src="/video/poline-to-blender.mp4" type="video/mp4" />
              </video>
              <span class="demo__video-label">poline → Blender</span>
            </div>
            <div class="demo__video-wrap">
              <video class="demo__video" autoplay loop muted playsinline>
                <source src="/video/poline-to-palette-shader.mp4" type="video/mp4" />
              </video>
