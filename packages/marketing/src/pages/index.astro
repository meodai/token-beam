      margin: 0;
    }

    .sec-lead {
      font-size: 1.0625rem;
      line-height: 1.55;
      color: var(--ink-2);
      margin: 0;
      max-width: 38rem;
    }

    /* --- Diagram Section --- */

    .diagram {
      padding: 5rem 0;
    }

    .diagram__svg {
      width: 100%;
      max-width: 50rem;
      height: auto;
      margin: 0 auto;
      display: block;
      font-family: var(--font-mono);
      overflow: visible;
    }

    .diagram__proto-text {
      fill: var(--bg);
    }

    .diagram__svg--mobile {
      display: none;
      overflow: visible;
    }

    .diagram__svg rect,
    .diagram__svg--mobile rect {
      fill: var(--surface);
    }

    @media (prefers-reduced-motion: reduce) {
      .diagram__svg animateTransform,
      .diagram__svg--mobile animateTransform {
        display: none;
      }
    }

    @media (max-width: 768px) {
      .diagram {
        padding: 2.5rem 0;
      }

      .diagram__svg {
        display: none;
      }

      .diagram__svg--mobile {
        display: block;
        width: 100%;
        max-width: 20rem;
        height: auto;
        margin: 0 auto;
      }
    }

    /* --- Demo Section --- */

    .demo {
      /* .sec provides padding + border-top */
    }

    .demo-frame {
      position: relative;
      border: 1px solid var(--link);
      padding: 1.25rem;
      border-radius: 4px;
      margin: 2rem 0 1.5rem;
    }

    .demo-frame__label {
      position: absolute;
      top: -0.55rem;
      left: 0.5rem;
      font-family: var(--font-mono);
      font-size: 0.625rem;
      color: var(--link);
      background: var(--surface);
      padding: 0 0.375rem;
      letter-spacing: 0.02em;
    }

    .demo__step-row {
      max-width: 30rem;
      margin: 0 auto 1.5rem;
      display: flex;
      align-items: baseline;
      gap: 0.75rem;
    }

    .demo__step-number {
      font-family: var(--font-sans);
      font-size: 1.5rem;
      line-height: 1;
      flex-shrink: 0;
      color: var(--text-subtle);
    }

    .demo__step-text {
      font-size: 0.95rem;
      color: var(--text-muted);
      margin: 0;
    }

    .demo__step-text a {
      color: var(--text);
      font-weight: 600;
    }

    .demo__videos {
      display: grid;
      grid-template-columns: repeat(2, 1fr);
      gap: 1rem;
      max-width: 48rem;
      margin: 1.5rem auto 0;
    }

    @media (max-width: 768px) {
      .demo__videos {
        grid-template-columns: 1fr;
      }
    }

    .demo__video-wrap {
      position: relative;
    }

    .demo__video {
      width: 100%;
      border: 2px solid var(--line);
      display: block;
    }

    .demo__video-label {
      display: block;
      margin-top: 0.35rem;
      font-size: 0.65rem;
      text-transform: uppercase;
      letter-spacing: 0.06em;
      color: var(--text-muted);
    }

    .demo__widget-wrap {
      max-width: 36rem;
      margin: 0 auto 1.5rem;
    }

    .demo__widget-wrap:last-child {
      margin-bottom: 0;
    }

    /* --- Plugins Section --- */

    /* --- Plugins + Websites shared card styles --- */

    .plugins__grid,
    .websites__grid {
      display: grid;
      grid-template-columns: repeat(auto-fill, minmax(14rem, 1fr));
      gap: 0.75rem;
    }

    .plugins__card,
    .websites__card {
      padding: 1.25rem 1.25rem 1rem;
      background: var(--surface);
      border: 1px solid var(--hair);
      border-radius: var(--radius);
      text-decoration: none;
      color: var(--ink);
      transition: border-color 0.15s var(--ease);
      display: flex;
      flex-direction: column;
    }

    .plugins__card:hover,
    .websites__card:hover {
      border-color: var(--link);
      color: var(--ink);
    }

    .plugins__card::after,
    .websites__card::after {
      content: none !important;
    }

    .plugins__card h3,
    .websites__card h3 {
      display: flex;
      align-items: center;
      gap: 0.5rem;
      font-size: 0.9375rem;
      font-weight: 600;
      letter-spacing: -0.01em;
      margin-bottom: 0.375rem;
    }

    .plugins__icon {
      width: 16px;
      height: 16px;
      margin-left: auto;
    }

    .plugins__card p,
    .websites__card p {
      font-size: 0.8125rem;
      color: var(--ink-2);
      line-height: 1.5;
      margin: 0;
    }

    .pills {
      margin-top: auto;
      padding-top: 0.875rem;
      display: flex;
      gap: 0.375rem;
    }

    .pill {
      display: inline-flex;
      align-items: center;
      font-size: 0.625rem;
      font-family: var(--font-mono);
      font-weight: 500;
      text-transform: none;
      letter-spacing: 0;
      padding: 0.2em 0.5em;
      border: 1px solid;
      border-radius: 999px;
      line-height: 1.3;
      background: var(--surface);
    }

    .pill--send {
      color: var(--c-green);
      border-color: var(--c-green);
    }

    .pill--receive {
      color: var(--c-violet);
      border-color: var(--c-violet);
    }

    .pill--both {
      color: var(--c-coral);
      border-color: var(--c-coral);
    }

    .websites__card--cta {
      border-style: dashed;
      color: var(--ink-3);
    }

    .websites__card--cta:hover {
      color: var(--ink);
    }

    /* --- Developers Section --- */

    /* --- Developers --- */

    .developers {
      /* .sec provides padding + border-top */
    }

    .developers__example {
      max-width: 48rem;
      margin: 0 0 1.5rem;
    }

    .developers__example pre {
      background: var(--ink) !important;
      padding: 1.5rem 1.75rem !important;
      overflow-x: auto;
      font-size: 0.8125rem !important;
      line-height: 1.7 !important;
      font-family: var(--font-mono) !important;
      border-radius: var(--radius) !important;
      border: none !important;
    }

    .developers__example code {
      background: none !important;
      border: none !important;
      padding: 0 !important;
      font-size: inherit !important;
      color: inherit !important;
      font-family: inherit !important;
    }

    .developers__tabs {
      display: inline-flex;
      max-width: 48rem;
      margin: 0 0 0.75rem;
      gap: 0.25rem;
      background: var(--surface-2);
      padding: 0.25rem;
      border-radius: var(--radius);
    }

    .developers__tab {
      padding: 0.375rem 0.875rem;
      background: transparent;
      border: none;
      border-radius: calc(var(--radius) - 2px);
      font-family: inherit;
      font-size: 0.8125rem;
      font-weight: 500;
      cursor: pointer;
      color: var(--ink-2);
      transition:
        background 0.15s var(--ease),
        color 0.15s var(--ease);
    }

    .developers__tab:hover {
      color: var(--ink);
    }

    .developers__tab.is-active {
      background: var(--surface);
      color: var(--ink);
      border: 1px solid var(--hair);
      padding: 0.3125rem 0.8125rem;
    }

    .developers__links {
      display: flex;
      gap: 0.625rem;
      justify-content: flex-start;
      margin-top: 0.5rem;
    }

    /* --- Features --- */

    .features {
      /* .sec provides padding + border-top */
    }

    .feature-grid {
      display: grid;
      grid-template-columns: 1fr 1fr;
      gap: 2rem 2.5rem;
      margin: 0;
      padding: 0;
    }

    .feature {
      margin: 0;
    }

    .feature dt {
      font-size: 1.0625rem;
      font-weight: 600;
      letter-spacing: -0.01em;
      color: var(--ink);
      display: flex;
      align-items: center;
      gap: 0.625rem;
      margin: 0 0 0.375rem;
    }

    .feat-dot {
      width: 0.625rem;
      height: 0.625rem;
      border-radius: 50%;
      flex-shrink: 0;
      display: inline-block;
    }

    .feature dd {
      margin: 0;
      font-size: 0.9375rem;
      line-height: 1.55;
      color: var(--ink-2);
      max-width: 30rem;
    }

    @media (max-width: 720px) {
      .feature-grid {
        grid-template-columns: 1fr;
        gap: 1.75rem;
      }
    }

    /* --- Footer --- */

    .site-footer {
      border-top: 1px solid var(--hair-2);
      background: var(--surface);
      margin-top: 4rem;
    }

    .site-footer__inner {
      max-width: var(--container-w);
      margin: 0 auto;
      padding: 2.5rem var(--gutter) 1.75rem;
      display: flex;
      justify-content: space-between;
      align-items: flex-end;
      gap: 2rem;
    }

    .site-footer__cols {
      display: flex;
      gap: 3rem;
    }

    .site-footer__col {
      display: flex;
      flex-direction: column;
      gap: 0.5rem;
    }

    .site-footer__label {
      font-size: 0.6875rem;
      color: #bbb;
      text-transform: uppercase;
      letter-spacing: 0.08em;
      margin-bottom: 0.25rem;
    }

    .site-footer__col a {
      font-size: 0.8125rem;
      color: var(--ink-2);
      text-decoration: none;
    }

    .site-footer__col a:hover {
      color: var(--link);
    }

    .site-footer__col a::after {
      content: none !important;
    }

    .site-footer__meta {
      text-align: right;
      font-family: var(--font-mono);
      font-size: 0.6875rem;
      color: var(--ink-3);
      line-height: 1.6;
    }

    @media (max-width: 720px) {
      .site-footer__inner {
        flex-direction: column;
        align-items: flex-start;
      }
      .site-footer__cols {
        gap: 2rem;
      }
      .site-footer__meta {
        text-align: left;
      }
    }

    /* --- Responsive --- */

    @media (max-width: 768px) {
      .nav--desktop {
        display: none;
      }

      .hero {
        padding: 0 0 3rem;
        text-align: left;
      }

      .hero__canvas {
        position: relative;
        height: 50vw;
        margin-bottom: 2rem;
      }

      .hero__inner {
        padding: 0 var(--gutter);
        align-items: flex-start;
      }

      .hero h1,
      .hero .hero-text,
      .hero .eyebrow,
      .hero .hero-buttons {
        max-width: 100%;
      }

      .hero-text {
        text-align: left;
      }

      .plugins__grid,
      .websites__grid {
        grid-template-columns: 1fr;
      }

      .developers__links {
        flex-direction: column;
        align-items: flex-start;
      }
    }

    .astro-code-themes {
      background: transparent !important;
    }
  </style>

  <script>
    import '../scripts/demo';
    import { initHeroScene } from '../scripts/hero-scene';

    const canvas = document.getElementById('hero-canvas') as HTMLCanvasElement;
    if (canvas) initHeroScene(canvas);

    document.querySelectorAll('.developers__tab').forEach((tab) => {
      tab.addEventListener('click', () => {
        const target = (tab as HTMLElement).dataset.tab;
        document
          .querySelectorAll('.developers__tab')
          .forEach((t) => t.classList.remove('is-active'));
        tab.classList.add('is-active');
        document.querySelectorAll('.developers__example[data-panel]').forEach((panel) => {
          (panel as HTMLElement).style.display =
            (panel as HTMLElement).dataset.panel === target ? '' : 'none';
        });
      });
    });
  </script>
</html>
