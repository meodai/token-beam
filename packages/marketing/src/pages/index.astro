      --c-violet: #a259ff;
      --c-cyan: #1abcfe;
      --c-green: #0acf83;
      --c-red: #f24822;
      --link: #0d99ff;

      /* compatibility aliases for existing sections (repainted per-checkpoint) */
      --text: var(--ink);
      --bg: var(--surface);
      --bg-layer-1: var(--surface);
      --interactive: var(--ink);
      --interactive-weak: var(--ink-2);
      --line: var(--hair);
      --success: var(--c-green);
      --text-muted: var(--ink-2);
      --text-subtle: var(--ink-3);

      /* fonts */
      --font-sans:
        'Inter', system-ui, -apple-system, 'Segoe UI', Roboto, sans-serif;
      --font-mono: ui-monospace, 'SF Mono', Menlo, Monaco, 'Courier New', monospace;

      /* type scale */
      --t-display: clamp(2.5rem, 6vw, 4rem);
      --t-h1: clamp(2rem, 4.5vw, 2.5rem);
      --t-h2: 1.5rem;
      --t-body: 1rem;
      --t-small: 0.8125rem;

      /* layout */
      --container-w: 75rem;
      --gutter: 2rem;
      --radius: 8px;

      --ease: cubic-bezier(0.3, 0.7, 0, 1);

      /* gradient signature */
      --grad-conic: conic-gradient(
        from 180deg at 50% 50%,
        var(--c-coral),
        var(--c-violet),
        var(--c-cyan),
        var(--c-green),
        var(--c-red),
        var(--c-coral)
      );
      --grad-linear: linear-gradient(
        90deg,
        var(--c-coral),
        var(--c-violet),
        var(--c-cyan),
        var(--c-green)
      );

      /* legacy dot-pattern kept only so sections that reference it still resolve
         — removed visually in Checkpoint 7 pass */
      --dot: transparent;
      --dot-r: 0.5px;
      --dot-space: 5px;
      --dot-pattern: none;
    }

